   "metadata": {},
   "source": [
    "\n",
    "### 9.2 Cluster Profiles\n",
    "Average values per cluster and eligibility rate per group.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d46c902c",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "FEATURES = [\n",
    "    'Estimated Income','TotalDebt','TotalAssets',\n",
    "    'DebtToIncomeRatio','AssetsToLoansRatio','Risk Weighting','Age'\n",
    "]\n",
    "profile_means = df.groupby('Cluster')[FEATURES].mean().round(2)\n",
    "counts = df['Cluster'].value_counts().sort_index()\n",
    "summary = profile_means.copy()\n",
    "summary['Clients'] = counts\n",
    "summary['% Eligible_realistic'] = df.groupby('Cluster')['Eligible_realistic'].mean().mul(100).round(1)\n",
    "summary\n"
   ]
  },
  {
